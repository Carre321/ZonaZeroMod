@BgMain   = #0b1220(0.92);
@BgSide   = #0f172a(0.92);
@BgPanel  = #0b1220(0.55);
@Outline  = #ffffff(0.08);

@TitleStyle    = LabelStyle(FontSize: 22, RenderUppercase: true, TextColor: #ffffff(0.95));
@SubTitleStyle = LabelStyle(FontSize: 14, TextColor: #ffffff(0.70), Wrap: true);
@SectionStyle  = LabelStyle(FontSize: 16, TextColor: #ffffff(0.85));

@Scroll = ScrollbarStyle(
  Size: 10,
  Spacing: 4,
  OnlyVisibleWhenHovered: false,
  Background: #000000(0.15),
  Handle: #ffffff(0.18),
  HoveredHandle: #ffffff(0.28),
  DraggedHandle: #ffffff(0.36)
);

Group {
  LayoutMode: Center;

  SceneBlur { Anchor: (Full: 0); }

  Panel #Main {
    Anchor: (Width: 1200, Height: 720);
    Padding: (Full: 12);
    LayoutMode: Left;
    Background: @BgMain;
    OutlineColor: @Outline;
    OutlineSize: 1;

    // LEFT
    Panel #LeftPanel {
      Anchor: (Width: 320, Full: 0);
      Padding: (Full: 12);
      LayoutMode: Top;
      Background: @BgSide;
      OutlineColor: @Outline;
      OutlineSize: 1;

      Label #LeftTitle { Text: "KITS"; Style: @TitleStyle; Anchor: (Left: 0, Right: 0, Height: 32, Bottom: 4); }
      Label #LeftSubtitle { Text: "Selecciona un kit"; Style: @SubTitleStyle; Anchor: (Left: 0, Right: 0, Height: 20, Bottom: 10); }

      Panel #KitList {
        Anchor: (Left: 0, Right: 0, Height: 520, Bottom: 10);
        Padding: (Full: 8);
        LayoutMode: TopScrolling;
        ScrollbarStyle: @Scroll;
        Background: @BgPanel;
        OutlineColor: @Outline;
        OutlineSize: 1;
      }

      TextButton #ClaimBtn { Text: "RECLAMAR"; Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 8); }
      TextButton #CloseBtn { Text: "CERRAR"; Anchor: (Left: 0, Right: 0, Height: 46); }
    }

    // RIGHT
    Panel #RightPanel {
      // Ancho fijo para que el panel NO se re-mida por el texto (evita que la ventana se descoloque al previsualizar)
      Anchor: (Left: 14, Top: 0, Bottom: 0, Width: 842);
      Padding: (Full: 12);
      LayoutMode: Top;
      Background: @BgSide;
      OutlineColor: @Outline;
      OutlineSize: 1;

      Label #KitNameLabel { Text: "Selecciona un kit"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 28, Bottom: 6); }
      Label #KitInfoLabel { Text: ""; Style: @SubTitleStyle; Anchor: (Left: 0, Right: 0, Height: 64, Bottom: 4); }
      Label #KitStatusLabel { Text: ""; Style: @SubTitleStyle; Anchor: (Left: 0, Right: 0, Height: 20, Bottom: 10); }

      Panel #RightScroll {
        Anchor: (Left: 0, Right: 0, Bottom: 0);
        FlexWeight: 1;
        Padding: (Full: 10);
        LayoutMode: TopScrolling;
        ScrollbarStyle: @Scroll;
        Background: @BgPanel;
        OutlineColor: @Outline;
        OutlineSize: 1;

        // STORAGE
        Group #StorageSection { LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Inventario"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #StorageSlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }

        // HOTBAR
        Group #HotbarSection { LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Hotbar"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #HotbarSlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }

        // ARMOR
        Group #ArmorSection { LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Armadura"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #ArmorSlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }

        // UTILITY (se mantiene)
        Group #UtilitySection { Visible: false; LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Utility"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #UtilitySlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }

        // TOOLS (oculto por estética; el código puede seguir llenándolo sin romper nada)
        Group #ToolsSection { Visible: false; LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Tools"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #ToolsSlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }

        // BACKPACK (visible + con scroll)
        Group #BackpackSection { LayoutMode: Top; Anchor: (Left: 0, Right: 0, Bottom: 14);
          Label { Text: "Backpack"; Style: @SectionStyle; Anchor: (Left: 0, Right: 0, Height: 22, Bottom: 6); }
          Group { LayoutMode: Center; Anchor: (Left: 0, Right: 0);
            Group #BackpackSlots { LayoutMode: LeftCenterWrap; Anchor: (Width: 624); }
          }
        }
      }
    }
  }
}
